{
  "ci": {
    "collect": {
      "startServerCommand": "npm run preview",
      "url": [
        "http://localhost:4173/",
        "http://localhost:4173/portfolio",
        "http://localhost:4173/feedback"
      ],
      "numberOfRuns": 3
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "categories:performance": "warn",
        "categories:accessibility": "warn",
        "categories:best-practices": "warn",
        "categories:seo": "warn",
        "categories:pwa": "warn"
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "./lighthouse-report"
    }
  }
}
