{
  "name": "budget-engineer-os",
  "private": true,
  "version": "4.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:only": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 1000",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:fast": "vitest run",
    "test:shard1": "vitest run --shard=1/3",
    "test:shard2": "vitest run --shard=2/3",
    "test:shard3": "vitest run --shard=3/3",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:ci": "npm run typecheck && npm run test:shard1 && npm run test:shard2 && npm run test:shard3 && npm run test:integration",
    "test:release": "npm run typecheck && npm run build:only && npm test && npm run test:integration",
    "test:smoke": "playwright test --config=playwright.config.ts",
    "lighthouse": "npm run build && lhci autorun"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@techstark/opencv-js": "^5.0.0-release.1",
    "@xenova/transformers": "^2.17.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "convert-units": "^2.3.4",
    "dexie": "^4.0.8",
    "fflate": "^0.8.3",
    "framer-motion": "^11.2.12",
    "immer": "^10.1.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.400.0",
    "makerjs": "^0.18.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.24.1",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.4.0",
    "three": "^0.179.1",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "vite-plugin-pwa": "^0.20.0",
    "vitest": "^3.2.7"
  }
}
